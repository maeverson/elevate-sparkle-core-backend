# Environment variables for local development
# Copy this file to .env and adjust values as needed

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/sparkledb
SPRING_DATASOURCE_USERNAME=sparkle
SPRING_DATASOURCE_PASSWORD=sparkle123

# AWS
CLOUD_AWS_REGION_STATIC=us-east-1
CLOUD_AWS_SQS_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# JWT
JWT_SECRET=your-256-bit-secret-key-change-this-in-production-min-32-chars
JWT_EXPIRATION=86400000

# Observability
MANAGEMENT_OTLP_TRACING_ENDPOINT=http://localhost:4317

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_ELEVATE_SPARKLE=DEBUG

# Spring profiles
SPRING_PROFILES_ACTIVE=dev
